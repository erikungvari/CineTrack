USE cinetrack;

INSERT INTO titles_by_genre (genre, title_id, title, year, type, duration_s, director, cast_list, avg_rating, description, poster_url) VALUES ('Action', a1111111-1111-1111-1111-111111111111, 'Inception', 2010, 'movie', 8880, 'Christopher Nolan', ['Leonardo DiCaprio', 'Joseph Gordon-Levitt', 'Elliot Page'], 4.7, 'A thief who steals corporate secrets through dream-sharing technology is given the inverse task of planting an idea into the mind of a C.E.O.', 'https://image.tmdb.org/t/p/w500/bgIt92V3IDysoAIcEfOo2ZK9PEv.jpg');
INSERT INTO titles_by_genre (genre, title_id, title, year, type, duration_s, director, cast_list, avg_rating, description, poster_url) VALUES ('Action', a2222222-2222-2222-2222-222222222222, 'Avengers: Endgame', 2019, 'movie', 10860, 'Anthony Russo', ['Robert Downey Jr.', 'Chris Evans', 'Scarlett Johansson'], 4.6, 'After the devastating events of Infinity War, the universe is in ruins. With the help of remaining allies, the Avengers assemble once more to reverse the actions of Thanos.', 'https://image.tmdb.org/t/p/w500/4dDYD0Ukpc7Y8MdBhIIPBgC2ynS.jpg');
INSERT INTO titles_by_genre (genre, title_id, title, year, type, duration_s, director, cast_list, avg_rating, description, poster_url) VALUES ('Action', a3333333-3333-3333-3333-333333333333, 'Avengers: Infinity War', 2018, 'movie', 8940, 'Anthony Russo', ['Robert Downey Jr.', 'Chris Hemsworth', 'Josh Brolin'], 4.5, 'The Avengers and their allies must sacrifice all in an attempt to defeat the powerful Thanos before his blitz of devastation puts an end to the universe.', 'https://image.tmdb.org/t/p/w500/or06FN3Dka5tukK1e9sl16pB3iy.jpg');
INSERT INTO titles_by_genre (genre, title_id, title, year, type, duration_s, director, cast_list, avg_rating, description, poster_url) VALUES ('Action', a4444444-4444-4444-4444-444444444444, 'Gladiator', 2000, 'movie', 9300, 'Ridley Scott', ['Russell Crowe', 'Joaquin Phoenix', 'Connie Nielsen'], 4.6, 'A former Roman General sets out to exact vengeance against the corrupt emperor who murdered his family and sent him into slavery.', 'https://image.tmdb.org/t/p/w500/oU3l8jJG1sKEvBRdE7uBTkfjDZD.jpg');

INSERT INTO titles_by_genre (genre, title_id, title, year, type, duration_s, director, cast_list, avg_rating, description, poster_url) VALUES ('Sci-Fi', b1111111-1111-1111-1111-111111111111, 'The Matrix', 1999, 'movie', 8160, 'The Wachowskis', ['Keanu Reeves', 'Laurence Fishburne', 'Carrie-Anne Moss'], 4.7, 'When a beautiful stranger leads computer hacker Neo to a forbidding underworld, he discovers the shocking truth about the life he knows.', 'https://image.tmdb.org/t/p/w500/f89U3ADr1oiB1s9GkdPOEpXUk5H.jpg');
INSERT INTO titles_by_genre (genre, title_id, title, year, type, duration_s, director, cast_list, avg_rating, description, poster_url) VALUES ('Sci-Fi', b2222222-2222-2222-2222-222222222222, 'Arrival', 2016, 'movie', 6960, 'Denis Villeneuve', ['Amy Adams', 'Jeremy Renner', 'Forest Whitaker'], 4.5, 'A linguist works with the military to communicate with alien lifeforms after twelve mysterious spacecraft appear around the world.', 'https://image.tmdb.org/t/p/w500/7IiTTgloJzvGI1TAYymCfbfl3vT.jpg');
INSERT INTO titles_by_genre (genre, title_id, title, year, type, duration_s, director, cast_list, avg_rating, description, poster_url) VALUES ('Sci-Fi', b3333333-3333-3333-3333-333333333333, 'Star Wars: A New Hope', 1977, 'movie', 7260, 'George Lucas', ['Mark Hamill', 'Harrison Ford', 'Carrie Fisher'], 4.7, 'Luke Skywalker joins forces with a Jedi Knight, a cocky pilot, a Wookiee and two droids to save the galaxy from the Empire.', 'https://image.tmdb.org/t/p/w500/6FfCtAuVAW8XJjZ7eWeLibRLWTw.jpg');
INSERT INTO titles_by_genre (genre, title_id, title, year, type, duration_s, director, cast_list, avg_rating, description, poster_url) VALUES ('Sci-Fi', b4444444-4444-4444-4444-444444444444, 'Back to the Future', 1985, 'movie', 6960, 'Robert Zemeckis', ['Michael J. Fox', 'Christopher Lloyd', 'Lea Thompson'], 4.6, 'Marty McFly, a 17-year-old high school student, is accidentally sent 30 years into the past in a time-traveling DeLorean.', 'https://image.tmdb.org/t/p/w500/vzmL6fP7aPKNKPRTFnZmiUfciyV.jpg');

INSERT INTO titles_by_genre (genre, title_id, title, year, type, duration_s, director, cast_list, avg_rating, description, poster_url) VALUES ('Drama', c1111111-1111-1111-1111-111111111111, 'Forrest Gump', 1994, 'movie', 8520, 'Robert Zemeckis', ['Tom Hanks', 'Robin Wright', 'Gary Sinise'], 4.8, 'The presidencies of Kennedy and Johnson, the Vietnam War, Watergate and other events unfold from the perspective of an Alabama man with an IQ of 75.', 'https://image.tmdb.org/t/p/w500/saHP97rTPS5eLmrLQEcANmKrsFl.jpg');
INSERT INTO titles_by_genre (genre, title_id, title, year, type, duration_s, director, cast_list, avg_rating, description, poster_url) VALUES ('Drama', c2222222-2222-2222-2222-222222222222, 'Fight Club', 1999, 'movie', 8340, 'David Fincher', ['Brad Pitt', 'Edward Norton', 'Helena Bonham Carter'], 4.7, 'An insomniac office worker and a devil-may-care soap maker form an underground fight club that evolves into much more.', 'https://image.tmdb.org/t/p/w500/pfPob0mrC1KiPVP9NXZnqvpks9u.jpg');
INSERT INTO titles_by_genre (genre, title_id, title, year, type, duration_s, director, cast_list, avg_rating, description, poster_url) VALUES ('Drama', c3333333-3333-3333-3333-333333333333, 'Pulp Fiction', 1994, 'movie', 9240, 'Quentin Tarantino', ['John Travolta', 'Uma Thurman', 'Samuel L. Jackson'], 4.8, 'The lives of two mob hitmen, a boxer, a gangsters wife, and a pair of diner bandits intertwine in four tales of violence and redemption.', 'https://image.tmdb.org/t/p/w500/aKuFiU82s5ISJpGZp7YkIr3kCUd.jpg');
INSERT INTO titles_by_genre (genre, title_id, title, year, type, duration_s, director, cast_list, avg_rating, description, poster_url) VALUES ('Drama', c4444444-4444-4444-4444-444444444444, 'Schindlers List', 1993, 'movie', 11700, 'Steven Spielberg', ['Liam Neeson', 'Ben Kingsley', 'Ralph Fiennes'], 4.9, 'In German-occupied Poland during World War II, industrialist Oskar Schindler gradually becomes concerned for his Jewish workforce.', 'https://image.tmdb.org/t/p/w500/oYuLEt3zVCKq57qu2F8dT7NIa6f.jpg');

INSERT INTO titles_by_genre (genre, title_id, title, year, type, duration_s, director, cast_list, avg_rating, description, poster_url) VALUES ('Comedy', d1111111-1111-1111-1111-111111111111, 'Superbad', 2007, 'movie', 6720, 'Greg Mottola', ['Jonah Hill', 'Michael Cera', 'Christopher Mintz-Plasse'], 4.1, 'Two co-dependent high school seniors are forced to deal with separation anxiety after their plan to stage a booze-soaked party goes awry.', 'https://image.tmdb.org/t/p/w500/xBHvZcjRiWyobQ9kxBhO6B2dtRI.jpg');
INSERT INTO titles_by_genre (genre, title_id, title, year, type, duration_s, director, cast_list, avg_rating, description, poster_url) VALUES ('Comedy', d2222222-2222-2222-2222-222222222222, 'The Hangover', 2009, 'movie', 6000, 'Todd Phillips', ['Bradley Cooper', 'Ed Helms', 'Zach Galifianakis'], 4.0, 'Three buddies wake up from a bachelor party in Las Vegas, with no memory of the previous night and the bachelor missing.', 'https://image.tmdb.org/t/p/w500/pMMrS9utJ9Rm6IrUHrAqyMoXsMD.jpg');
INSERT INTO titles_by_genre (genre, title_id, title, year, type, duration_s, director, cast_list, avg_rating, description, poster_url) VALUES ('Comedy', d3333333-3333-3333-3333-333333333333, 'Parasite', 2019, 'movie', 7920, 'Bong Joon-ho', ['Song Kang-ho', 'Lee Sun-kyun', 'Cho Yeo-jeong'], 4.8, 'Greed and class discrimination threaten the newly formed symbiotic relationship between the wealthy Park family and the destitute Kim clan.', 'https://image.tmdb.org/t/p/w500/d5iIlFn5s0ImszYzBPb8JPIfbXD.jpg');
INSERT INTO titles_by_genre (genre, title_id, title, year, type, duration_s, director, cast_list, avg_rating, description, poster_url) VALUES ('Comedy', d4444444-4444-4444-4444-444444444444, 'Whiplash', 2014, 'movie', 6360, 'Damien Chazelle', ['Miles Teller', 'J.K. Simmons'], 4.7, 'A promising young drummer enrolls at a cut-throat music conservatory where his dreams of greatness are mentored by an instructor who will stop at nothing.', 'https://image.tmdb.org/t/p/w500/7fn624j5lj3xTme2SgiLCeuedmO.jpg');

INSERT INTO titles_by_genre (genre, title_id, title, year, type, duration_s, director, cast_list, avg_rating, description, poster_url) VALUES ('Horror', e1111111-1111-1111-1111-111111111111, 'Hereditary', 2018, 'movie', 7620, 'Ari Aster', ['Toni Collette', 'Milly Shapiro', 'Gabriel Byrne'], 4.3, 'A grieving family is haunted by tragic and disturbing occurrences after the death of their secretive grandmother.', 'https://image.tmdb.org/t/p/w500/velWPhVMQeQKcxggNEU8YmIo52R.jpg');
INSERT INTO titles_by_genre (genre, title_id, title, year, type, duration_s, director, cast_list, avg_rating, description, poster_url) VALUES ('Horror', e2222222-2222-2222-2222-222222222222, 'Midsommar', 2019, 'movie', 8580, 'Ari Aster', ['Florence Pugh', 'Jack Reynor', 'Vilhelm Blomgren'], 4.1, 'A couples trip to a midsummer festival in Sweden turns sinister when the locals reveal their terrifying traditions.', 'https://image.tmdb.org/t/p/w500/lr3cYNDlJcpT1EWzFH42aSIvkab.jpg');
INSERT INTO titles_by_genre (genre, title_id, title, year, type, duration_s, director, cast_list, avg_rating, description, poster_url) VALUES ('Horror', e3333333-3333-3333-3333-333333333333, 'The Conjuring', 2013, 'movie', 6720, 'James Wan', ['Vera Farmiga', 'Patrick Wilson', 'Lili Taylor'], 4.2, 'Paranormal investigators Ed and Lorraine Warren work to help a family terrorized by a dark presence in their farmhouse.', 'https://image.tmdb.org/t/p/w500/rCzpDGLbOoPwLjy3OAm5NUPOTrC.jpg');
INSERT INTO titles_by_genre (genre, title_id, title, year, type, duration_s, director, cast_list, avg_rating, description, poster_url) VALUES ('Horror', e4444444-4444-4444-4444-444444444444, 'Alien', 1979, 'movie', 6960, 'Ridley Scott', ['Sigourney Weaver', 'Tom Skerritt', 'John Hurt'], 4.6, 'The crew of a commercial spacecraft encounters a deadly lifeform after investigating a mysterious transmission of unknown origin.', 'https://image.tmdb.org/t/p/w500/9E2y5Q7WlCVNEhP5GiVTjhEhx1o.jpg');
INSERT INTO titles_by_genre (genre, title_id, title, year, type, duration_s, director, cast_list, avg_rating, description, poster_url) VALUES ('Horror', e5555555-5555-5555-5555-555555555555, 'The Shining', 1980, 'movie', 8640, 'Stanley Kubrick', ['Jack Nicholson', 'Shelley Duvall', 'Danny Lloyd'], 4.5, 'A family heads to an isolated hotel for the winter where a sinister presence influences the father into violence.', 'https://image.tmdb.org/t/p/w500/sKCr78MXSLixwmZ8DyJLrpMsd15.jpg');

INSERT INTO titles_by_genre (genre, title_id, title, year, type, duration_s, director, cast_list, avg_rating, description, poster_url) VALUES ('Thriller', f1111111-1111-1111-1111-111111111111, 'Joker', 2019, 'movie', 7320, 'Todd Phillips', ['Joaquin Phoenix', 'Robert De Niro', 'Zazie Beetz'], 4.5, 'A mentally troubled standup comedian embarks on a downward spiral that leads to the creation of an iconic villain.', 'https://image.tmdb.org/t/p/w500/udDclJoHjfjb8Ekgsd4FDteOkCU.jpg');
INSERT INTO titles_by_genre (genre, title_id, title, year, type, duration_s, director, cast_list, avg_rating, description, poster_url) VALUES ('Thriller', f2222222-2222-2222-2222-222222222222, 'Se7en', 1995, 'movie', 7620, 'David Fincher', ['Brad Pitt', 'Morgan Freeman', 'Gwyneth Paltrow'], 4.6, 'Two detectives, a rookie and a veteran, hunt a serial killer who uses the seven deadly sins as his motives.', 'https://image.tmdb.org/t/p/w500/6yoghtyTpznpBik8EngEmJskVUO.jpg');
INSERT INTO titles_by_genre (genre, title_id, title, year, type, duration_s, director, cast_list, avg_rating, description, poster_url) VALUES ('Thriller', f3333333-3333-3333-3333-333333333333, 'The Silence of the Lambs', 1991, 'movie', 7080, 'Jonathan Demme', ['Jodie Foster', 'Anthony Hopkins'], 4.7, 'A young F.B.I. cadet must receive the help of an incarcerated and manipulative cannibal killer to catch another serial killer.', 'https://image.tmdb.org/t/p/w500/uS9m8OBk1RVfSPynEk5r5WcfMBi.jpg');
INSERT INTO titles_by_genre (genre, title_id, title, year, type, duration_s, director, cast_list, avg_rating, description, poster_url) VALUES ('Thriller', f4444444-4444-4444-4444-444444444444, 'Gone Girl', 2014, 'movie', 8940, 'David Fincher', ['Ben Affleck', 'Rosamund Pike'], 4.4, 'With his wifes disappearance having become the focus of an intense media circus, a man sees the spotlight turned on him.', 'https://image.tmdb.org/t/p/w500/lv5xShBIDPe7m4ufdTMpOSCJAJY.jpg');
INSERT INTO titles_by_genre (genre, title_id, title, year, type, duration_s, director, cast_list, avg_rating, description, poster_url) VALUES ('Thriller', f5555555-5555-5555-5555-555555555555, 'Shutter Island', 2010, 'movie', 8280, 'Martin Scorsese', ['Leonardo DiCaprio', 'Mark Ruffalo', 'Ben Kingsley'], 4.4, 'In 1954, a U.S. Marshal investigates the disappearance of a murderer who escaped from a hospital for the criminally insane.', 'https://image.tmdb.org/t/p/w500/4GDy0PHYX3VRXUtwK5ysFbg3kEx.jpg');

